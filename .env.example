# Google Maps Platform — Places API (Text Search + Place Details)
# Get one at: https://console.cloud.google.com/google/maps-apis/credentials
# Enable the "Places API" on the project.
GOOGLE_PLACES_API_KEY=

# Anthropic Claude API — used for review analysis (Haiku 4.5) and pitch generation (Sonnet 4.6)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Apollo.io API key — OPTIONAL. Only needed if you run with --enrich.
# https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=
